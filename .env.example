# GitHub App credentials
# Copy this file to .env and fill in your values
# NEVER commit your real .env file to git

# Your GitHub App's unique ID (found in App settings)
APP_ID=your_app_id_here

# Path to your GitHub App's private key file
PRIVATE_KEY_PATH=./private-key.pem

# Your GitHub App's webhook secret (set this when creating the app)
WEBHOOK_SECRET=your_webhook_secret_here

# GitHub token for local testing (optional)
GITHUB_TOKEN=your_github_token_here

# Port for local development (default: 3000)
PORT=3000

# Set to 'development' for local dev, 'production' for deployment
NODE_ENV=development
